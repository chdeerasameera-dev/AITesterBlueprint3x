{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/health",   "destination": "/api/health.js"   },
    { "source": "/api/generate", "destination": "/api/generate.js" },
    { "source": "/(.*)",         "destination": "/$1"              }
  ]
}
